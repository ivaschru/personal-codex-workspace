{
  "schemaVersion": 1,
  "initialized": false,
  "template": {
    "source": "https://github.com/ivaschru/personal-agent-workspace",
    "version": "2.3.0"
  },
  "updates": {
    "channel": "stable",
    "autoCheck": true,
    "checkIntervalHours": 24,
    "autoApply": true,
    "autoCommit": true,
    "autoPush": true,
    "rollbackOnFailure": true,
    "stopOnlyOnUnsafeState": true
  },
  "contributions": {
    "allowDraftPullRequests": true,
    "allowPublicIssues": false,
    "requireCleanReproduction": true,
    "requirePrivacyScan": true,
    "securityReportsPrivate": true
  },
  "owner": {
    "displayName": "TODO",
    "language": "ru",
    "timezone": "TODO"
  },
  "privacy": {
    "repositoryVisibility": "unknown",
    "profileTracked": false,
    "sensitiveDocumentsInGit": false,
    "secretsInGit": false
  },
  "storage": {
    "largeFiles": "local-only",
    "backup": "not-configured"
  },
  "modules": [],
  "features": {
    "tasks": true,
    "projects": true,
    "entities": false,
    "externalIntegrations": {
      "setupMode": "on-demand",
      "enabled": []
    }
  }
}
